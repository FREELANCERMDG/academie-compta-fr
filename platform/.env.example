# ====== Secrets de la plateforme (copier en .env et compléter) ======
# Clé de signature des sessions/CSRF — METTRE UNE VALEUR ALÉATOIRE LONGUE
SESSION_SECRET=changez-moi-par-une-chaine-aleatoire-de-64-caracteres-minimum

# Port d'écoute
PORT=3000

# Production : true active les cookies Secure + HSTS (nécessite HTTPS)
PRODUCTION=false

# Compte administrateur initial (créé au 1er démarrage si absent)
ADMIN_EMAIL=admin@exemple.mg
ADMIN_PASSWORD=ChangezCeMotDePasseAdmin!2026

# ====== Orange Money — API automatique (OPTIONNEL) ======
# Laisser vide pour utiliser le mode "manuel" (numéro dans config.json).
# À obtenir sur https://developer.orange.com/apis/om-webpay après création d'un compte marchand.
OM_BASE_URL=
OM_CLIENT_ID=
OM_CLIENT_SECRET=
OM_MERCHANT_KEY=
OM_RETURN_URL=
OM_CANCEL_URL=
OM_NOTIF_URL=

# ====== Paiement carte (OPTIONNEL) — ex. Stripe ======
CARD_PSP=
CARD_SECRET_KEY=
CARD_PUBLIC_KEY=
